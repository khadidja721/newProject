{
  "name": "plumber-ai-agent",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev --workspace server\" \"npm:dev --workspace web\"",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "lint": "eslint .",
    "test": "vitest --run"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^9.9.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.3"
  }
}
